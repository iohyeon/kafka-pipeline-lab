  "panels": [
    {
      "title": "── Spring Boot Application ──",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "HTTP Request Rate (req/sec)",
      "description": "Spring Boot HTTP 요청 처리량. 부하테스트 시 TPS 확인용",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"kafka-pipeline-lab\"}[1m])",
          "legendFormat": "{{method}} {{uri}} [{{status}}]"
        }
      ]
    },
    {
      "title": "HTTP Response Time (p99 / p95 / avg)",
      "description": "응답 시간 백분위수. 부하 시 p99가 급등하면 병목",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{job=\"kafka-pipeline-lab\"}[1m]))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"kafka-pipeline-lab\"}[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "rate(http_server_requests_seconds_sum{job=\"kafka-pipeline-lab\"}[1m]) / rate(http_server_requests_seconds_count{job=\"kafka-pipeline-lab\"}[1m])",
          "legendFormat": "avg"
        }
      ]
    },
    {
      "title": "HTTP Error Rate",
      "description": "5xx 에러 비율. 0%가 정상",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"kafka-pipeline-lab\",status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{job=\"kafka-pipeline-lab\"}[1m]))",
          "legendFormat": "Error Rate"
        }
      ]
    },
